---
---
/* Global Styles */
body { font-family: sans-serif; line-height: 1.6; max-width: 1200px; margin: 0 auto; padding: 20px; }
img { max-width: 100%; height: auto; display: block; border-radius: 20px; }

/* Landing page */
.tabular-list {
  list-style: none;
  padding: 0;
}

.tabular-item {
  display: grid !important;
  /* Column 1 is exactly 100px, Column 2 takes the rest */
  grid-template-columns: 100px 1fr; 
  gap: 10px;
  align-items: baseline;
  margin-bottom: 8px;
}

.post-date {
  /* font-family: sans-serif; */
  color: #444;
  white-space: nowrap; /* Forces date to stay on one line */
}

.post-title a {
  text-decoration: none;
  /* font-weight: 500; */
}

.post-cat {
  color: #bbb;
  margin-left: 8px;
}

/* Mobile: Stack them if the screen is too narrow */
@media (max-width: 500px) {
  .tabular-list li {
    grid-template-columns: 1fr;
    gap: 2px;
    margin-bottom: 20px;
  }
}

/* THE MASTER GRID */
.site-wrapper {
  display: grid;
  /* Col 1: flexible | Col 2: fixed 650px | Col 3: flexible */
  grid-template-columns: 1fr minmax(0, 650px) 1fr;
  /* min-height: 100vh; */
}

/* PUSH EVERYTHING INTO THE CENTRE COLUMN */
header, main, footer {
  grid-column: 2; /* Always stay in the middle track */
  width: 100%;
}

/* Ensure the header and nav are left-aligned WITHIN that 650px track */
header {
  padding-top: 0.5rem; 
  margin-bottom: 0.5rem; 
  text-align: left;
}

nav {
  display: flex;
  gap: 10px;
  margin-top: 0.5rem;
}

/* RESPONSIVE: If the screen is narrower than 650px, use padding instead */
@media (max-width: 500px) {
  .site-wrapper {
    grid-template-columns: 20px 1fr 20px;
  }
}


/* 1. BLOG LAYOUT (Single Column) */
.blog-article-layout {
  max-width: 650px;  /* Optimal reading width */
  margin: 0 auto;
  
  h1 { font-size: 2.5rem; margin-bottom: 0.5rem; }
  .post-meta { color: #666; font-style: italic; margin-bottom: 2rem; }
  
}

/* 2. PHOTOS CATEGORY */

/* The Gallery Grid (Index page) */
.photo-grid-index {
  display: grid !important;
  grid-template-columns: repeat(2, 1fr) !important; /* Force 2 columns */
  gap: 20px;
  width: 100%;
}

.photo-card {
  text-decoration: none;
  color: #333;
  display: flex;
  flex-direction: column;
}

.card-thumb {
  width: 100%;
  aspect-ratio: 1 / 1; /* Makes the thumbnail a perfect square */
  background-size: cover;
  background-position: center;
  background-color: #eee; /* Placeholder color if image is missing */
  border-radius: 4px;
}

/* Ensure images INSIDE the posts don't break the Index grid */
.photo-grid-index img {
  display: none; /* We use the background-image div for the index */
}

/* Individual Post Grid (Inside the article) */
.photos-post-content {
  display: grid;
  grid-template-columns: repeat(2, 1fr); 
  gap: 15px;
  
  /* The Kramdown Fix */
  p { display: contents; }
  
  p, h1, h2, h3, ul, ol {
    grid-column: 1 / -1;
    display: block;
    margin-bottom: 1.5rem;
  }
  
  figure, img {
    grid-column: span 1;
    width: 100%;
    aspect-ratio: 1 / 1; 
    object-fit: cover;
  }
}

/* Responsive: Drop to 2 or 1 column on smaller screens */
@media (max-width: 500px) {
  .site-wrapper {
    grid-template-columns: 15px 1fr 15px;
  }

  .photos-post-content {
    grid-template-columns: 1fr;
  }

  .photos-grid-index {
    grid-template-columns: 1fr !important;
  }
}

/* Grid Item Wrapper */
.photos-post-content figure { 
  margin: 0; 
  display: flex; 
  flex-direction: column; 
} 

/* Caption Styling */
figcaption {
  margin-top: 8px;
  font-size: 0.85rem;
  color: #666;
  line-height: 1.4;
  text-align: left; /* Keeps your alignment consistent */
}

/* Ensure images still behave in the grid */
.photos-post-content figure img {
  width: 100%;
  aspect-ratio: 1 / 1;
  object-fit: cover;
  border-radius: 4px;
}

/* 3. RECIPE LAYOUT */
.recipe-layout {
  max-width: 1000px;
  margin: 0 auto;
  
  .recipe-container {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 40px;
    margin-top: 2rem;
  }

  .ingredients {
    background: #f9f9f9;
    padding: 20px;
    border-radius: 8px;
    height: fit-content;
  }

  @media (max-width: 600px) {
    .recipe-container { grid-template-columns: 1fr; }
  }
}
.recipe-index {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
  gap: 20px;
  margin-top: 2rem;
}

.recipe-card {
  border: 1px solid #eee;
  padding: 15px;
  border-radius: 8px;
  transition: transform 0.2s;
  
  &:hover { transform: translateY(-3px); border-color: #ccc; }
  h3 { margin: 0 0 10px 0; color: #d35400; /* A nice "foodie" orange */ }
  p { margin: 0; font-size: 0.9rem; color: #666; }
}

/* Code Block Styling */
pre, code {
  font-family: monospace;
  font-size: 0.9rem;
}

/* The actual box around triple-backtick blocks */
figure.highlight, pre {
  background: #f4f4f4;
  padding: 1.5rem;
  border-radius: 8px;
  border: 1px solid #ddd;
  overflow-x: auto; /* Adds a scrollbar if the code is too wide */
  margin: 2rem 0;
}

/* Inline code (like `this`) */
p code {
  background: #eee;
  padding: 2px 5px;
  border-radius: 4px;
}

/* Basic Syntax Highlighting */
.highlight .k  { color: #d73a49; font-weight: bold; } /* Keywords (assign, if) */
.highlight .s  { color: #032f62; }                  /* Strings */
.highlight .nt { color: #22863a; }                  /* HTML Tags (div, span) */
.highlight .na { color: #6f42c1; }                  /* Attributes (class, style) */
.highlight .c  { color: #6a737d; font-style: italic; } /* Comments */

/* 1. Make the container relative so we can pin the tab to it */
figure.highlight, div.highlighter-rouge {
  position: relative;
  margin: 2rem 0;
}

/* 2. Create the "Tab" base style */
div.highlighter-rouge::before {
  position: absolute;
  top: 0;
  left: 0;
  padding: 5px 12px;
  font-size: 0.7rem;
  font-weight: bold;
  text-transform: uppercase;
  color: #888;
  background: #e0e0e0;
  border-bottom-left-radius: 8px;
  border-top-right-radius: 8px;
  pointer-events: none; /* Keeps it from interfering with clicks */
  z-index: 10;
}

/* 3. Map the Jekyll classes to specific labels */
div.language-liquid::before { content: "Liquid"; }
div.language-json::before   { content: "JSON"; }
div.language-scss::before   { content: "SCSS"; }
div.language-html::before   { content: "HTML"; }
div.language-js::before     { content: "JavaScript"; }

/* 4. Tweak the pre-box so the code doesn't overlap the tab */
pre.highlight {
  padding-top: 2.5rem !important; /* Makes room for the tab */
}

